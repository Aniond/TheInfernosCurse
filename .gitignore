*.yymps
*.yymp

# macOS artifacts
.DS_Store
__MACOSX/

# Windows artifacts
Thumbs.db
Desktop.ini

# IDE project lock (GameMaker creates this while open)
*.lock

# ── General ──────────────────────────────────────────────────────────────────
*.log
*.bak
*.orig

# ── Project docs (local reference only, not version controlled) ──────────────
story_bible.md
core_systems.md
dev_setup.md
ai_integration.md

# ── Misc root-level files ─────────────────────────────────────────────────────
*.winmd
*.exe
*.code-workspace

# ── External tooling (not game content) ──────────────────────────────────────
ComfyUI/

# ── Secrets / local credentials (never commit) ───────────────────────────────
config.ini
.mcp.json

# ── Local-only staging & reference material (not version controlled) ─────────
# Library install staging scratch (zips + extracted GM libs)
_lib_staging/
# Reference PDFs (large rulebooks / grimoires, local reference only)
refrences/
# Burst-test / debug screenshots (regenerated, large)
screenshots/
# Source image staging before GameMaker import
sprite_import/
# PixelLab API reference (local reference doc)
instructions/pixellab_api_reference.md
