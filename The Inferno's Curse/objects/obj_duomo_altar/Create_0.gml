// =============================================================================
// obj_duomo_altar — Create
// =============================================================================
// The high altar in the apse. While the church still holds (Limbo corruption
// below 100) stepping within range eases Benedetto's corruption a little and
// logs a chronicle line. At 100% the church has forgotten what it was: the altar
// is broken and no longer relieves anything.
interact_range = 80;
player_near    = false;
triggered      = false;   // one-shot — re-arms when the player walks away
